        "jsCode": "const posts = Array.isArray($input.first().json.posts) ? $input.first().json.posts : [];\nconst maxButtonsPerMessage = 10;\n\nconst truncateTitle = (title) => {\n  if (!title) {\n    return 'Open post';\n  }\n\n  const normalizedTitle = String(title).replace(/\\s+/g, ' ').trim();\n  return normalizedTitle.length > 60 ? `${normalizedTitle.slice(0, 57)}...` : normalizedTitle;\n};\n\nif (!posts.length) {\n  return [\n    {\n      json: {\n        message: 'No posts found for this source.'\n      }\n    }\n  ];\n}\n\nconst output = [];\n\nfor (let index = 0; index < posts.length; index += maxButtonsPerMessage) {\n  const postChunk = posts.slice(index, index + maxButtonsPerMessage);\n\n  output.push({\n    json: {\n      message: index === 0 ? 'Choose a post:' : 'More posts:',\n      buttons: {\n        inline_keyboard: postChunk.map((post) => ([\n          {\n            text: truncateTitle(post.title),\n            url: post.url\n          }\n        ]))\n      }\n    }\n  });\n}\n\nreturn output;"
