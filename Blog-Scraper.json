    {
      "parameters": {
        "jsCode": "const rawSources = Array.isArray($input.first().json.sources) ? $input.first().json.sources : [];\nconst labels = rawSources\n  .map((item) => {\n    if (typeof item === 'string') {\n      return item;\n    }\n\n    return item.text || item.name || '';\n  })\n  .filter(Boolean);\n\nconst keyboard = [];\n\nfor (let index = 0; index < labels.length; index += 2) {\n  keyboard.push(labels.slice(index, index + 2));\n}\n\nreturn {\n  message: 'Choose a website:',\n  buttons: {\n    keyboard\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
